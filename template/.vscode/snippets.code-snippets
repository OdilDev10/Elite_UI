    "EliteUI Stateful Component": {
        "prefix": "elite-stateful",
        "description": "Create an EliteUI component with reactive state",
        "body": [
            "class ${1:Name} extends SimpleComponent {",
            "    constructor(selector, props = {}) {",
            "        super(selector, {",
            "            ${2:count}: 0,",
            "            ${3:loading}: false,",
            "            ...props,",
            "        })",
            "    }",
            "",
            "    increment() {",
            "        this.setState(prev => ({ count: prev.count + 1 }))",
            "    }",
            "",
            "    decrement() {",
            "        this.setState(prev => ({ count: Math.max(0, prev.count - 1) }))",
            "    }",
            "",
            "    render() {",
            "        if (!this.el) return",
            "        this.el.innerHTML = this.loadTemplate('${4:${1:name}}')",
            "    }",
            "}",
            "",
            "window.${1:Name} = ${1:Name}"
        ]
    },
    "EliteUI Form Component": {
        "prefix": "elite-form",
        "description": "Create an EliteUI form component with validation",
        "body": [
            "class ${1:Name}Form extends SimpleComponent {",
            "    constructor(selector, props = {}) {",
            "        super(selector, {",
            "            fields: {},",
            "            errors: {},",
            "            submitting: false,",
            "            ...props,",
            "        })",
            "        this._props = { onSubmit: null, ...props }",
            "    }",
            "",
            "    validate(field, value) {",
            "        return $validators.required(value)",
            "    }",
            "",
            "    handleInput(e) {",
            "        const { name, value } = e.target",
            "        this.setState({",
            "            fields: { ...this._state.fields, [name]: value },",
            "            errors: { ...this._state.errors, [name]: null },",
            "        })",
            "    }",
            "",
            "    async handleSubmit(e) {",
            "        e.preventDefault()",
            "        const { fields } = this._state",
            "        const errors = {}",
            "",
            "        Object.keys(fields).forEach(key => {",
            "            const error = this.validate(key, fields[key])",
            "            if (error) errors[key] = error",
            "        })",
            "",
            "        if (Object.keys(errors).length > 0) {",
            "            this.setState({ errors })",
            "            return",
            "        }",
            "",
            "        this.setState({ submitting: true })",
            "        try {",
            "            await this._props.onSubmit?.(fields)",
            "        } finally {",
            "            this.setState({ submitting: false })",
            "        }",
            "    }",
            "",
            "    render() {",
            "        if (!this.el) return",
            "        this.el.innerHTML = this.loadTemplate('${4:form-${1:name}}')",
            "    }",
            "}",
            "",
            "window.${1:Name}Form = ${1:Name}Form"
        ]
    },
    "EliteUI List Component": {
        "prefix": "elite-list",
        "description": "Create an EliteUI component for rendering lists",
        "body": [
            "class ${1:Name}List extends SimpleComponent {",
            "    constructor(selector, props = {}) {",
            "        super(selector, {",
            "            items: [],",
            "            loading: false,",
            "            emptyMessage: 'No items found',",
            "            ...props,",
            "        })",
            "    }",
            "",
            "    async loadItems() {",
            "        this.setState({ loading: true })",
            "        try {",
            "            const items = await ${2:this.fetchItems}()",
            "            this.setState({ items, loading: false })",
            "        } catch (err) {",
            "            this.setState({ loading: false })",
            "            this._handleError(err)",
            "        }",
            "    }",
            "",
            "    render() {",
            "        if (!this.el) return",
            "        this.el.innerHTML = this.loadTemplate('${3:list-${1:name}}')",
            "    }",
            "}",
            "",
            "window.${1:Name}List = ${1:Name}List"
        ]
    },
    "EliteUI Modal Component": {
        "prefix": "elite-modal",
        "description": "Create an EliteUI modal component",
        "body": [
            "class ${1:Name}Modal extends SimpleComponent {",
            "    constructor(selector, props = {}) {",
            "        super(selector, {",
            "            open: false,",
            "            title: '${2:Modal Title}',",
            "            ...props,",
            "        })",
            "        this._props = { onClose: null, ...props }",
            "    }",
            "",
            "    open() {",
            "        this.setState({ open: true })",
            "        document.body.style.overflow = 'hidden'",
            "    }",
            "",
            "    close() {",
            "        this.setState({ open: false })",
            "        document.body.style.overflow = ''",
            "        this._props.onClose?.()",
            "    }",
            "",
            "    handleBackdropClick(e) {",
            "        if (e.target === e.currentTarget) this.close()",
            "    }",
            "",
            "    handleKeydown(e) {",
            "        if (e.key === 'Escape') this.close()",
            "    }",
            "",
            "    render() {",
            "        if (!this.el) return",
            "        this.el.innerHTML = this.loadTemplate('${3:modal-${1:name}}')",
            "    }",
            "}",
            "",
            "window.${1:Name}Modal = ${1:Name}Modal"
        ]
    },
    "EliteUI Service": {
        "prefix": "elite-service",
        "description": "Create a new EliteUI service class",
        "body": [
            "class ${1:Name}Service {",
            "    constructor() {",
            "        this._baseUrl = $env.get('${2:API_URL}', '')",
            "        this._http = $http.create({ baseUrl: this._baseUrl })",
            "    }",
            "",
            "    async getAll() {",
            "        return this._http.get('${3:/endpoint}')",
            "    }",
            "",
            "    async getById(id) {",
            "        return this._http.get(`${3:/endpoint}/${id}`)",
            "    }",
            "",
            "    async create(data) {",
            "        return this._http.post('${3:/endpoint}', data)",
            "    }",
            "",
            "    async update(id, data) {",
            "        return this._http.put(`${3:/endpoint}/${id}`, data)",
            "    }",
            "",
            "    async delete(id) {",
            "        return this._http.delete(`${3:/endpoint}/${id}`)",
            "    }",
            "}",
            "",
            "const ${1:name}Service = new ${1:Name}Service()",
            "export { ${1:name}Service }"
        ]
    },
    "EliteUI Store": {
        "prefix": "elite-store",
        "description": "Create a new EliteUI reactive store",
        "body": [
            "class ${1:Name}Store extends SimpleStore {",
            "    constructor() {",
            "        super({",
            "            ${2:items}: [],",
            "            ${3:loading}: false,",
            "            ${4:error}: null,",
            "        })",
            "    }",
            "",
            "    async fetchItems() {",
            "        this.setState({ loading: true, error: null })",
            "        try {",
            "            const items = await $http.get('${5:/api/items}')",
            "            this.setState({ items, loading: false })",
            "        } catch (err) {",
            "            this.setState({ error: err.message, loading: false })",
            "        }",
            "    }",
            "",
            "    addItem(item) {",
            "        const items = [...this._state.items, item]",
            "        this.setState({ items })",
            "    },",
            "",
            "    removeItem(id) {",
            "        const items = this._state.items.filter(i => i.id !== id)",
            "        this.setState({ items })",
            "    },",
            "}",
            "",
            "const ${1:name}Store = new ${1:Name}Store()",
            "export { ${1:name}Store }"
        ]
    },
