{
    "EliteUI Component": {
        "prefix": "elite-component",
        "description": "Create a new EliteUI component extending SimpleComponent",
        "body": [
            "class ${1:Name} extends SimpleComponent {",
            "    constructor(selector, props = {}) {",
            "        super(selector, {",
            "            ${2:prop}: ${3:value},",
            "            ...props,",
            "        })",
            "        this._props = { ...props }",
            "    }",
            "",
            "    render() {",
            "        if (!this.el) return",
            "        this.el.innerHTML = this.loadTemplate('${4:${1:name}}')",
            "    }",
            "}",
            "",
            "window.${1:Name} = ${1:Name}"
        ]
    },
