{
  "name": "@odineck/elite-ui",
  "version": "1.0.0",
  "type": "module",
  "description": "Production-ready vanilla JavaScript framework - zero runtime dependencies",
  "main": "core/index.js",
  "module": "core/index.js",
  "files": [
    "core",
    "dist",
    "template",
    "scripts/create.js",
    "README.md",
    ".eslintrc.json"
  ],
  "bin": {
    "create-elite-ui": "./scripts/create.js"
  },
  "scripts": {
    "create": "node scripts/create.js",
    "bundle": "node scripts/bundle.cjs",
    "lint": "eslint core/ components/ pages/ --fix",
    "lint:check": "eslint core/ components/ pages/",
    "test": "echo 'Tests coming soon'"
  },
  "devDependencies": {
    "eslint": "^8.57.1"
  },
  "keywords": [
    "vanilla-js",
    "framework",
    "reactive",
    "components",
    "router",
    "state-management",
    "security",
    "form-validation",
    "zero-dependencies"
  ],
  "author": "Odineck",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/odineck/elite-ui.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}
